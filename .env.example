# Copy to .env and fill in your local paths
# All paths are optional — features gracefully degrade when unset

# BioNetGen paths (auto-detected from PyBioNetGen if not set)
# Override only if you have a custom BNG2 installation:
# BNG2_PATH=/path/to/BNG2.pl
# NFSIM_PATH=/path/to/NFsim
# BNGPATH=/path/to/bionetgen/root

# Perl executable (defaults to "perl")
PERL_PATH=perl

# Emscripten SDK root (only needed for WASM builds)
EMSDK_PATH=
